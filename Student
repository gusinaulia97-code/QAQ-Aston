// Создайте класс Student, содержащий следующие характеристики – имя, группа, курс, оценки по предметам. 
// Создайте коллекцию, содержащую объекты класса Student. Следует написать метод, который удаляет студентов
// со средним баллом < 3, а также отдельный метод, который переводит студента на следующий курс, если средний балл >= 3.
// Напишите метод printStudents(Set<Student> students, int course), который получает список студентов и номер курса.
// Метод печатает на консоль имена тех студентов, которые обучаются на данном курсе.

public class Student {
    private String name;
    private int group;
    private int course;
    private List<Double> grades;

    public Student(String name, int group, int course, List<Double> grades) {
        this.name = name;
        this.group = group;
        this.course = course;
        this.grades = grades;
    }
    public String getName() {
        return name;
    }
    public int getGroup() {
        return group;
    }
    public int getCourse() {
        return course;
    }
    public List<Double> getGrades() {
        return grades;
    }
    public double calculateAverageGrade() {
        double sum = 0;
        for (Double grade : grades) {
            sum += grade;
        }
        return sum / grades.size();
    }
    public static void removeLowGradeStudents(Set<Student> students) {
        Iterator<Student> iterator = students.iterator();
        while (iterator.hasNext()) {
            Student student = iterator.next();
            if (student.calculateAverageGrade() < 3) {
                iterator.remove();
            }
        }
    }

    public void moveToNextCourse() {
        if (course < 4) { // Например, максимум 4 курса
            course++;
            System.out.println("Студент переведен на следующий курс");
        } else {
            System.out.println("Максимальный курс");
        }
    }
    public static void printStudents(Set<Student> students, int course) {
        System.out.printf("Студенты на курсе %d:\n", course);
        for (Student student : students) {
            if (student.getCourse() == course) {
                System.out.printf("%s (средний балл: %.2f)\n", student.getName(), student.calculateAverageGrade());
            }
        }
    }
}

public class Main {
    public static void main(String args) {
        Set<Student> studentSet = new HashSet<>();
        
        studentSet.add(new Student("Иван", 1, 2, Arrays.asList(3.0, 3.5, 4.5)));
        studentSet.add(new Student("Юлия", 1, 3, Arrays.asList(3.0, 2.5, 3.0)));
        studentSet.add(new Student("Ева", 2, 2, Arrays.asList(4.5, 4.5, 5.0)));

        Student.printStudents(studentSet, 2);
        
        Student.removeLowGradeStudents(studentSet);
        
        System.out.println("\nПосле удаления:");
        Student.printStudents(studentSet, 2);
    }
}
