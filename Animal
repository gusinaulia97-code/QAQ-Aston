public class Cat {
    private String name;
    private boolean satiety;

    public Cat(String name) {
        this.name = name;
        this.satiety = false;
    }

    public String getName() {
        return name;
    }

    public boolean isSatiety() {
        return satiety;
    }

    public boolean eat(Bowl bowl, int amount) {
        if (bowl.takeFood(amount)) {
            this.satiety = true;
            return true;
        }
        return false;
    }

    @Override
    public String toString() {
        return "Кот " + name + ", сытость: " + satiety;
    }
}

class Bowl {
    private int food;

    public Bowl(int initialFood) {
        this.food = initialFood;
    }

    public int getFood() {
        return food;
    }

    public boolean takeFood(int amount) {
        if (food >= amount) {
            food -= amount;
            return true;
        }
        return false;
    }

    public void addFood(int amount) {
        if (amount > 0) {
            food += amount;
        }
    }

    @Override
    public String toString() {
        return "Миска, количество еды: " + food;
    }
}

public class Main {
    public static void main(String[] args) {
        Bowl bowl = new Bowl(20);
        System.out.println(bowl);

        Cat[] cats = {
            new Cat("Барсик"),
            new Cat("Мурзик"),
            new Cat("Черныш"),
            new Cat("Рыжик")
        };

        for (Cat cat : cats) {
            System.out.println(cat.getName() + " пытается поесть 7 единиц еды...");
            cat.eat(bowl, 7);
            System.out.println(cat);
        }

        System.out.println("\nПосле трапезы:");
        System.out.println(bowl);
        for (Cat cat : cats) {
            System.out.println(cat);
        }

        System.out.println("\nДобавляем 15 единиц еды в миску...");
        bowl.addFood(15);
        System.out.println(bowl);

        System.out.println(cats[0].getName() + " снова пытается поесть 10 единиц еды...");
        cats[0].eat(bowl, 10);
        System.out.println(cats[0]);
        System.out.println(bowl);
    }
}
